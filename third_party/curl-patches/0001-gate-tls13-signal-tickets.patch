From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
Subject: [PATCH] vtls/mbedtls: gate tls13_enable_signal_new_session_tickets on TLS 1.3

mbedtls_ssl_conf_tls13_enable_signal_new_session_tickets() is only
defined in mbedTLS when MBEDTLS_SSL_PROTO_TLS1_3 is enabled. curl's
guard only checks MBEDTLS_SSL_SESSION_TICKETS, which breaks builds
against a minimal mbedTLS config that has session tickets for 1.2
resumption but no TLS 1.3.

---
 lib/vtls/mbedtls.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/lib/vtls/mbedtls.c b/lib/vtls/mbedtls.c
index 0000000..0000001 100644
--- a/lib/vtls/mbedtls.c
+++ b/lib/vtls/mbedtls.c
@@ -747,7 +747,8 @@ mbed_connect_step1(struct Curl_cfilter *cf, struct Curl_easy *data)
     return CURLE_SSL_CONNECT_ERROR;
   }

-#ifdef MBEDTLS_SSL_SESSION_TICKETS
+#if defined(MBEDTLS_SSL_SESSION_TICKETS) && \
+    defined(MBEDTLS_SSL_PROTO_TLS1_3)
   /* New in mbedTLS 3.6.1, need to enable, default is now disabled */
   mbedtls_ssl_conf_tls13_enable_signal_new_session_tickets(&backend->config,
     MBEDTLS_SSL_TLS1_3_SIGNAL_NEW_SESSION_TICKETS_ENABLED);
--
2.30.0
